# Fincore agent layer .env
# Copy to .env. Internal tool, no inbound exposure, but this holds live tokens.
# Keep it locked down: chmod 600 .env

# --- Firefly III ---
FIREFLY_III_URL=http://firefly.internal.lan:8080
FIREFLY_III_PAT=paste_personal_access_token_here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
CATEGORIZER_MODEL=claude-haiku-4-5-20251001

# --- Discord ---
DISCORD_BOT_TOKEN=paste_bot_token_here
DISCORD_FINANCE_CHANNEL_ID=000000000000000000

# --- Behavior knobs ---
# Confidence at or above this is auto-applied; below it becomes a Discord ask.
CONFIDENCE_THRESHOLD=0.80
# Max transactions sent to the model per run (cost control, mirrors the Gmail agent cap).
CATEGORIZE_CAP=40
# How many days back to scan for uncategorized transactions.
LOOKBACK_DAYS=30
# Firefly tags used as processing markers.
TAG_DONE=ai-categorized
TAG_REVIEW=needs-review
# Rule group that auto-created merchant rules land in.
RULE_GROUP_TITLE=AI Categorized

# --- Optional: trigger the Data Importer autoimport before categorizing ---
# Leave blank to skip. If set, agent-daily POSTs here to pull new transactions first.
# See the Firefly III data-importer autoimport docs for the URL + secret format.
IMPORTER_AUTOIMPORT_URL=
IMPORTER_AUTOIMPORT_SECRET=
