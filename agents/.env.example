# Fincore agent layer .env
# Copy to .env. Internal tool, no inbound exposure, but this holds live tokens.
# Keep it locked down: chmod 600 .env

# --- Firefly III ---
FIREFLY_III_URL=http://firefly.internal.lan:8080
FIREFLY_III_PAT=paste_personal_access_token_here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
CATEGORIZER_MODEL=claude-haiku-4-5-20251001

# --- Discord ---
DISCORD_BOT_TOKEN=paste_bot_token_here
DISCORD_FINANCE_CHANNEL_ID=000000000000000000
# Comma-separated Discord user ids allowed to trigger writes (button clicks, cat replies).
# Fail-closed: if empty, the bot rejects all categorization commands.
# Enable Developer Mode in Discord, right-click your profile, Copy User ID.
DISCORD_ALLOWED_USER_IDS=

# --- Store ---
# Path to fincore.db (memory, outcomes, baseline, audit). Defaults to ./fincore.db
# in this directory. The baseline is irreplaceable; back this file up.
FINCORE_DB_PATH=

# --- Backups (fincore-backup PM2 job) ---
# Destination for daily fincore.db copies. Point it OFF this host (e.g. an NFS
# mount to the NAS). Unset = the backup job exits loudly instead of running.
FINCORE_BACKUP_DIR=
# Daily copies to keep.
FINCORE_BACKUP_KEEP=14

# --- SimpleFIN balance oracle (SPEC 19 as amended) ---
# Daily balance snapshots for investment-ish accounts connected in the SimpleFIN
# Bridge but deliberately NEVER mapped into Firefly (Empower 401k, Coinbase).
# SIMPLEFIN_ACCESS_URL is the exchanged access URL (same value as the stack's
# SIMPLEFIN_TOKEN). VALUATION_ACCOUNT_MATCH is comma-separated case-insensitive
# substrings matched against org + account name; ONLY matches are ingested, so an
# importer-mapped checking account can never double-count. Both unset = oracle off.
# Schwab is INCLUDED here: net worth takes Schwab balances from the oracle (zero
# maintenance), while the Trader API sidecar below is analytics detail only.
SIMPLEFIN_ACCESS_URL=
VALUATION_ACCOUNT_MATCH=empower,coinbase,schwab

# --- Schwab (read-only POSITION DETAIL for analytics; net worth does NOT depend on this) ---
# App key + secret from developer.schwab.com (Trader API - Individual). The token
# file is created by `npm run schwab-auth` (interactive, needs a browser). Schwab
# expires refresh tokens every 7 days; when it lapses, position-level analytics
# (Phase 11: TLH, drift, concentration) pause and the heartbeat says so, but net
# worth keeps flowing through the SimpleFIN oracle. Renew whenever convenient.
# Unset SCHWAB_APP_KEY = Schwab pass off.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=./schwab-token.json
# Python interpreter for the sidecar; defaults to schwab/.venv/bin/python when
# present, else python3.
SCHWAB_PYTHON=

# --- Quality passes (matching, freshness, reconciliation) ---
# Lookback for the transfer/reimbursement matching pass (reimbursements need a
# long window; the transfer date window itself stays a few days).
MATCH_LOOKBACK_DAYS=90
# Max Firefly writes per matching run.
MATCH_WRITE_CAP=20
# A bank account with no imported transaction in this many days counts stale.
# Raise it if a quiet savings account produces noise.
FRESHNESS_THRESHOLD_DAYS=7

# --- Off-host dead man's switch ---
# healthchecks.io-style ping URL. agent-daily GETs it after each run (and /fail on
# failure); the monitor alerts when pings STOP, which covers a dead PM2 host/LXC.
HEALTHCHECK_PING_URL=

# --- Behavior knobs ---
# Confidence at or above this is auto-applied; below it becomes a Discord ask.
CONFIDENCE_THRESHOLD=0.80
# Max transactions sent to the model per run (cost control, mirrors the Gmail agent cap).
CATEGORIZE_CAP=40
# Transactions per model call; small chunks keep each response inside its token budget.
CATEGORIZE_CHUNK_SIZE=15
# How many days back to scan for uncategorized transactions.
LOOKBACK_DAYS=30
# Firefly tags used as processing markers.
TAG_DONE=ai-categorized
TAG_REVIEW=needs-review
# Rule group that auto-created merchant rules land in.
RULE_GROUP_TITLE=AI Categorized

# --- Optional: trigger the Data Importer autoimport before categorizing ---
# Leave blank to skip. If set, agent-daily POSTs {IMPORTER_URL}/autoimport?directory=..&secret=..
# before categorizing. Requires CAN_POST_AUTOIMPORT=true, AUTO_IMPORT_SECRET (16+ chars),
# and IMPORT_DIR_ALLOWLIST on the importer container, plus import config JSON files in
# the directory. See firefly-stack/README.md. Note the trigger is fire-and-forget: rows
# it pulls may only be categorized on the next daily run.
IMPORTER_URL=
IMPORTER_AUTOIMPORT_SECRET=
IMPORTER_AUTOIMPORT_DIR=/import
