# Fincore: Firefly III stack .env
# Copy to .env in the same directory as compose.yaml and fill in real values.
# This file is internal-only and not exposed to inbound traffic, but it holds live
# read tokens to your bank and brokerage, so keep the stack directory permissions tight
# (for example: chmod 600 .env, and restrict the stack dir to your user).

# --- Timezone ---
TZ=America/New_York

# --- Pinned image versions (do NOT track latest; the app does automated writes) ---
# Set these to the current stable tags before deploying, and bump deliberately
# (snapshot, change tag, re-test writes). Check the current stable versions at
# https://github.com/firefly-iii/firefly-iii/releases and the data-importer releases.
FIREFLY_VERSION=version-6.6.3
IMPORTER_VERSION=SET_ME_check_data-importer_releases

# --- Ports (host side) ---
FIREFLY_PORT=8080
IMPORTER_PORT=8081

# --- External URL of the Firefly III UI ---
# Use the address you actually browse to (LAN IP or internal hostname).
APP_URL=http://firefly.internal.lan:8080

# --- Firefly III app key ---
# Must be EXACTLY 32 characters. Generate one with:
#   head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32; echo
APP_KEY=CHANGE_ME_32_CHARACTER_RANDOM_STRING

# --- Database credentials ---
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=CHANGE_ME_db_password
DB_ROOT_PASSWORD=CHANGE_ME_db_root_password

# --- Data Importer -> Firefly III ---
# Create this AFTER first boot: Firefly UI > Options > Profile > OAuth >
# Personal Access Tokens > Create new token. Paste the full token here.
# Leave blank on the very first bring-up; the importer can start once it is set.
FIREFLY_III_ACCESS_TOKEN=

# --- SimpleFIN ---
# The access URL you get after exchanging your one-time SimpleFIN claim token.
# See README.md step 3. Store the exchanged URL here (the claim token is single use).
SIMPLEFIN_TOKEN=
